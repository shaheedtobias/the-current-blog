---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ContentCard from '../../components/ContentCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPosts } from '../../lib/sanity';
import { urlFor } from '../../lib/sanity';
import { format } from 'date-fns';

const posts = await getPosts();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Blog`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="container">
			<section class="page-header">
				<h1 class="font-heading text-heading-xl">Blog</h1>
				<p class="font-body text-body-md">All articles</p>
			</section>

			{posts.length > 0 ? (
				<section class="posts-grid">
					{posts.map((post) => (
						<ContentCard
							title={post.title}
							excerpt={post.excerpt}
							image={post.mainImage ? urlFor(post.mainImage).url() : undefined}
							date={post.publishedAt ? format(new Date(post.publishedAt), 'MMM d, yyyy') : undefined}
							category={post.categories?.[0]?.title}
							orientation="horizontal"
							url={`/blog/${post.slug.current}`}
						/>
					))}
				</section>
			) : (
				<section class="empty-state">
					<p class="font-body text-body-md">No posts yet. Create your first post in the Sanity Studio.</p>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		padding: var(--spacing-12) 0;
		margin-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.page-header h1 {
		margin-bottom: var(--spacing-2);
	}

	.page-header p {
		color: var(--color-muted);
	}

	.posts-grid {
		display: grid;
		gap: var(--spacing-6);
		margin-bottom: var(--spacing-16);
	}

	@media (min-width: 768px) {
		.posts-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.empty-state {
		padding: var(--spacing-16) 0;
		text-align: center;
		color: var(--color-muted);
	}
</style>
