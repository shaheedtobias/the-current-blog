---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import ContentCard from '../../components/ContentCard.astro';
import { SITE_TITLE } from '../../consts';
import { getSeriesBySlug, getPostsBySeries, getSeries } from '../../lib/sanity';
import { urlFor } from '../../lib/sanity';
import { format } from 'date-fns';

export async function getStaticPaths() {
	const series = await getSeries();
	return series.map((s: any) => ({
		params: { slug: s.slug.current },
		props: { slug: s.slug.current },
	}));
}

const { slug } = Astro.props;
const series = await getSeriesBySlug(slug);
const posts = series ? await getPostsBySeries(series._id) : [];

if (!series) {
	return Astro.redirect('/404');
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${series.title} - ${SITE_TITLE}`} description={series.description || ''} />
	</head>
	<body>
		<Header />
		<main class="container">
			<section class="series-header">
				{series.coverImage && (
					<img src={urlFor(series.coverImage).url()} alt={series.title} class="series-header__image" />
				)}
				<div class="series-header__content">
					<h1 class="font-heading text-heading-xl">{series.title}</h1>
					{series.description && (
						<p class="font-body text-body-md series-header__description">{series.description}</p>
					)}
				</div>
			</section>

			{posts.length > 0 ? (
				<section class="posts-list">
					<h2 class="font-heading text-heading-lg">Articles in this series</h2>
					<div class="posts-list__items">
						{posts.map((post: any, index: number) => (
							<div class="post-item">
								<span class="post-item__number font-meta">{index + 1}</span>
								<ContentCard
									title={post.title}
									excerpt={post.excerpt}
									image={post.mainImage ? urlFor(post.mainImage).url() : undefined}
									date={post.publishedAt ? format(new Date(post.publishedAt), 'MMM d, yyyy') : undefined}
									category={post.categories?.[0]?.title}
									orientation="horizontal"
									url={`/blog/${post.slug.current}`}
								/>
							</div>
						))}
					</div>
				</section>
			) : (
				<section class="empty-state">
					<p class="font-body text-body-md">No articles in this series yet.</p>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.series-header {
		padding: var(--spacing-12) 0;
		margin-bottom: var(--spacing-8);
		border-bottom: 1px solid var(--color-border);
	}

	.series-header__image {
		width: 100%;
		height: 300px;
		object-fit: cover;
		border-radius: var(--radius-md);
		margin-bottom: var(--spacing-6);
	}

	.series-header__content h1 {
		margin-bottom: var(--spacing-4);
	}

	.series-header__description {
		color: var(--color-muted);
		max-width: 720px;
	}

	.posts-list {
		margin-bottom: var(--spacing-16);
	}

	.posts-list h2 {
		margin-bottom: var(--spacing-6);
	}

	.posts-list__items {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-6);
	}

	.post-item {
		display: flex;
		gap: var(--spacing-4);
		align-items: flex-start;
	}

	.post-item__number {
		font-size: 2rem;
		font-weight: 700;
		color: var(--color-accent);
		min-width: 48px;
		text-align: center;
		line-height: 1;
	}

	.empty-state {
		padding: var(--spacing-16) 0;
		text-align: center;
		color: var(--color-muted);
	}
</style>
